    <section class="gm-tab-page {{#if activeTabs.exams}}active{{/if}}" data-gm-page="exams">
      <article class="gm-panel exam-rules-banner">
        <header class="gm-panel-header class-catalog-hero">
          <div>
            <span class="section-label">Study & Testing</span>
            <h2>Exam Process</h2>
            <p>Run Strixhaven exams in one sitting: prep first, then testing, with rerolls and cheating handled at the table.</p>
          </div>
        </header>
      </article>
      <div class="exam-rules-strip exam-study-rules exam-rules-top">
        <section>
          <strong>Study</strong>
          <span>DM sets the study DC after hearing the student's study method and comparing it to the exam.</span>
          <span>Success grants 1 reroll during the test.</span>
        </section>
        <section>
          <strong>Study Together</strong>
          <span>Group study gives advantage on the study roll.</span>
          <span>Success grants 1 reroll during the test.</span>
        </section>
        <section>
          <strong>All-Nighter</strong>
          <span>Success grants 2 rerolls during the test.</span>
          <span>The student also takes 1 level of exhaustion for the exam.</span>
        </section>
        <section>
          <strong>Cheating</strong>
          <span>Cheaters use Deception and Sleight of Hand against the cheating DC.</span>
          <span>If caught, they fail and face discipline/standing consequences.</span>
        </section>
      </div>

      <section class="exam-manager">
        <aside class="gm-panel exam-roster">
          <header class="student-directory-header">
            <div>
              <span class="section-label">Exam Archive</span>
              <h2>Exams</h2>
            </div>
            <button type="button" data-action="add-row" data-collection="exams"><i class="fas fa-plus"></i> Add</button>
          </header>
          <div class="student-roster-stats">
            <div><strong>{{examCards.length}}</strong><span>Total</span></div>
            <div><strong>{{examClassGroups.length}}</strong><span>Groups</span></div>
            <div><strong>{{data.students.length}}</strong><span>Students</span></div>
          </div>
          {{#each examClassGroups}}
            <details class="student-college-group exam-class-group" open>
              <summary>{{this.name}} <span>{{this.exams.length}}</span></summary>
              <div class="student-roster-list">
                {{#each this.exams}}
                  <button type="button" class="student-roster-card exam-roster-card {{#if this.selected}}active{{/if}}" data-action="select-exam" data-id="{{this.id}}">
                    <i class="fas fa-scroll"></i>
                    <div>
                      <strong>{{this.name}}</strong>
                      <span>DC {{this.dc}} &middot; {{this.checkOne}} / {{this.checkTwo}}</span>
                      <small>{{this.classSummary}}</small>
                    </div>
                  </button>
                {{/each}}
              </div>
            </details>
          {{else}}
            <p class="gm-muted">No exams yet. Add an exam, then run its checks from the detail panel.</p>
          {{/each}}
        </aside>

        {{#if selectedExam}}
          <section class="exam-profile">
            <article class="student-dossier-hero gm-panel exam-dossier-hero">
              <div class="student-portrait exam-portrait">
                <i class="fas fa-scroll"></i>
              </div>
              <div class="student-title-block">
                <span class="section-label">Exam Record</span>
                <h2>{{selectedExam.name}}</h2>
                <p>{{selectedExam.classSummary}} &middot; DC {{selectedExam.dc}}</p>
                <div class="student-tag-strip">
                  <span>{{selectedExam.checkOne}}</span>
                  <span>{{selectedExam.checkTwo}}</span>
                  <span>{{selectedExam.studentResults.length}} student records</span>
                </div>
              </div>
              <div class="student-profile-actions">
                <button type="button" class="danger" data-action="delete-row" data-collection="exams" data-id="{{selectedExam.id}}"><i class="fas fa-trash"></i> Remove</button>
              </div>
            </article>

            <section class="student-dossier-grid exam-dossier-grid">
              <article class="gm-panel student-section-wide memory-panel">
                <header class="student-section-header">
                  <div>
                    <span class="section-label">Exam Setup</span>
                    <h2>Class, DC & Checks</h2>
                  </div>
                  <small>Push rolls from this record when the test begins.</small>
                </header>
                <div class="gm-form-grid three">
                  <label><span>Exam Name</span><input data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="name" value="{{selectedExam.name}}" placeholder="Exam name"></label>
                  <label>
                    <span>Class</span>
                    <select data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="classId">
                      {{#each selectedExam.classOptions}}
                        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label><span>DC</span><input type="number" data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="dc" value="{{selectedExam.dc}}"></label>
                  <label>
                    <span>Check 1</span>
                    <select data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="checkOne">
                      {{#each selectedExam.checkOneOptions}}
                        <option value="{{this.label}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label>
                    <span>Check 2</span>
                    <select data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="checkTwo">
                      {{#each selectedExam.checkTwoOptions}}
                        <option value="{{this.label}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                </div>
              </article>

              <article class="gm-panel student-section-wide memory-panel">
                <span class="section-label">Exam Notes</span>
                <h2>Scenario, Stakes & Professor Expectations</h2>
                <label class="exam-notes-field"><span>Notes</span><textarea data-action="save-row" data-collection="exams" data-id="{{selectedExam.id}}" data-field="notes" placeholder="Exam scenario, topics, proctor, special rules...">{{selectedExam.notes}}</textarea></label>
              </article>

              <article class="gm-panel student-section-wide memory-panel">
                <header class="student-section-header">
                  <div>
                    <span class="section-label">Testing</span>
                    <h2>Roll Pushes</h2>
                  </div>
                  <small>Students marked as cheating are skipped by normal pushes.</small>
                </header>
                <div class="exam-push-all-strip">
                  <button type="button" data-action="push-exam-roll-all" data-exam-id="{{selectedExam.id}}" data-field="testOneRoll" data-check-label="{{selectedExam.checkOne}}">
                    Push {{selectedExam.checkOne}} to All Students
                  </button>
                  <button type="button" data-action="push-exam-roll-all" data-exam-id="{{selectedExam.id}}" data-field="testTwoRoll" data-check-label="{{selectedExam.checkTwo}}">
                    Push {{selectedExam.checkTwo}} to All Students
                  </button>
                </div>
              </article>

              <section class="exam-student-results student-section-wide">
                <h3>Student Exam Records</h3>
                {{#each selectedExam.studentResults}}
                  <article class="exam-student-row" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}">
                    <header>
                      <strong>{{this.studentName}}</strong>
                      <span data-exam-result-summary>{{this.finalResult}} &middot; Standing {{this.standingDelta}}</span>
                    </header>
                    <div class="exam-result-grid simplified">
                      <label><span>{{../selectedExam.checkOne}}</span><input type="number" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="testOneRoll" value="{{this.testOneRoll}}"></label>
                      <label><span>{{../selectedExam.checkTwo}}</span><input type="number" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="testTwoRoll" value="{{this.testTwoRoll}}"></label>
                      <label><span>Calculated Outcome</span><input data-exam-calculated-outcome value="{{this.finalResult}}" readonly></label>
                    </div>
                    <section class="exam-cheat-package {{#if this.cheated}}active{{/if}}">
                      <label class="exam-check-card">
                        <input type="checkbox" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="cheated" {{#if this.cheated}}checked{{/if}}>
                        <span>Cheated</span>
                        <small>Skip normal exam pushes. Resolve with Deception and Sleight of Hand.</small>
                      </label>
                      <label><span>Cheating DC</span><input type="number" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="cheatingDc" value="{{this.cheatingDc}}"></label>
                      <label class="exam-roll-field">
                        <span>Deception</span>
                        <div>
                          <input type="number" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="cheatingDeceptionRoll" value="{{this.cheatingDeceptionRoll}}">
                          <button type="button" data-action="push-exam-roll" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-actor-id="{{this.actorId}}" data-field="cheatingDeceptionRoll" data-check-label="Deception">Push</button>
                        </div>
                      </label>
                      <label class="exam-roll-field">
                        <span>Sleight of Hand</span>
                        <div>
                          <input type="number" data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="cheatingSleightRoll" value="{{this.cheatingSleightRoll}}">
                          <button type="button" data-action="push-exam-roll" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-actor-id="{{this.actorId}}" data-field="cheatingSleightRoll" data-check-label="Sleight of Hand">Push</button>
                        </div>
                      </label>
                    </section>
                    <label class="exam-result-notes"><span>Notes</span><textarea data-action="save-exam-result" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" data-field="notes">{{this.notes}}</textarea></label>
                    <footer>
                      <span data-exam-current-standing>Current: {{this.standing}} {{this.standingScore}}</span>
                      <button type="button" data-action="apply-exam-standing" data-exam-id="{{../selectedExam.id}}" data-result-id="{{this.id}}" {{#if this.standingApplied}}disabled{{/if}}>
                        {{#if this.standingApplied}}Standing Applied{{else}}Apply Standing Change{{/if}}
                      </button>
                    </footer>
                  </article>
                {{/each}}
              </section>
            </section>
          </section>
        {{else}}
          <article class="gm-panel student-empty-state">
            <h2>No exam selected</h2>
            <p>Add an exam or project to begin tracking study prep, test checks, and standing changes.</p>
          </article>
        {{/if}}
      </section>
    </section>

    <section class="gm-tab-page {{#if activeTabs.clubs}}active{{/if}}" data-gm-page="clubs">
      <article class="gm-panel club-rules-panel club-rules-banner">
        <header class="gm-panel-header">
          <div>
            <span class="section-label">Extracurricular Rules</span>
            <h2>Campus Clubs & Societies</h2>
            <p>Students can benefit from two extracurriculars, or one if they also hold a campus job.</p>
          </div>
        </header>
      </article>
      <div class="club-rule-grid club-rules-top">
        <section>
          <strong>Student Die</strong>
          <span>Each extracurricular grants one d4. It can be added to an ability check using one of that club's listed skills.</span>
        </section>
        <section>
          <strong>One Use</strong>
          <span>A Student Die can be rolled after the d20, before success or failure is declared, then refreshes after a long rest.</span>
        </section>
        <section>
          <strong>Relationship Point</strong>
          <span>Participation grants either a positive or negative Relationship Point with one NPC member of that club.</span>
        </section>
        <section>
          <strong>Joining & Quitting</strong>
          <span>New benefits are normally gained at the start of an academic year. Quitting immediately removes the benefit.</span>
        </section>
      </div>

      <section class="club-manager">
        <aside class="gm-panel club-roster">
          <header class="student-directory-header">
            <div>
              <span class="section-label">Extracurriculars</span>
