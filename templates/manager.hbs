                  </label>
                  <label><span>Scene ID</span><input data-action="save-row" data-collection="campusLocations" data-id="{{selectedCampusLocation.id}}" data-field="sceneId" value="{{selectedCampusLocation.sceneId}}" placeholder="Foundry Scene ID"></label>
                  <label class="student-section-wide"><span>Notable NPC / Contact</span><input data-action="save-row" data-collection="campusLocations" data-id="{{selectedCampusLocation.id}}" data-field="notableNpc" value="{{selectedCampusLocation.notableNpc}}" placeholder="Professor, student, staff member, spirit..."></label>
                </div>
              </article>

              <article class="gm-panel student-section-wide memory-panel">
                <span class="section-label">Description</span>
                <h2>What Students See</h2>
                <label><span>Description</span><textarea data-action="save-row" data-collection="campusLocations" data-id="{{selectedCampusLocation.id}}" data-field="description" placeholder="Public description, atmosphere, normal activity...">{{selectedCampusLocation.description}}</textarea></label>
              </article>

              <article class="gm-panel student-section-wide memory-panel">
                <span class="section-label">Secrets</span>
                <h2>DM-Only Discoveries</h2>
                <label><span>Secrets</span><textarea data-action="save-row" data-collection="campusLocations" data-id="{{selectedCampusLocation.id}}" data-field="secrets" placeholder="Hidden doors, mysteries, restricted rooms, rumors...">{{selectedCampusLocation.secrets}}</textarea></label>
              </article>

              <article class="gm-panel student-section-wide memory-panel">
                <span class="section-label">DM Notes</span>
                <h2>Scene Hooks & Future Use</h2>
                <label><span>Notes</span><textarea data-action="save-row" data-collection="campusLocations" data-id="{{selectedCampusLocation.id}}" data-field="notes" placeholder="Encounter ideas, event hooks, maps, reminders...">{{selectedCampusLocation.notes}}</textarea></label>
              </article>
            </section>
          </section>
        {{else}}
          <article class="gm-panel student-empty-state">
            <h2>No campus location selected</h2>
            <p>Add a location to begin building the Strixhaven campus archive.</p>
          </article>
        {{/if}}
      </section>
    </section>

    <section class="gm-tab-page {{#if activeTabs.calendar}}active{{/if}}" data-gm-page="calendar">
      <section class="gm-board two">
        <article class="gm-panel">
          <header class="gm-panel-header">
            <h2>Daily Schedule</h2>
            <button type="button" data-action="advance-day"><i class="fas fa-sun"></i> Advance Day</button>
          </header>
          <div class="gm-callout calendar-source">
            <span>Calendar Integration</span>
            <p>{{data.calendar.source}}{{#if data.calendar.dateLabel}} &middot; {{data.calendar.dateLabel}}{{/if}}</p>
          </div>
          <div class="simple-calendar-board">
            <header class="simple-calendar-board-header">
              <div>
                <span class="section-label">Simple Calendar Month</span>
                <h3>{{calendarMonth.title}}</h3>
              </div>
              <small>{{calendarMonth.source}}</small>
            </header>
            {{#if calendarMonth.connected}}
              <div class="simple-calendar-month-grid">
                {{#each calendarMonth.days}}
                  <button type="button" class="simple-calendar-day {{#if this.isToday}}today{{/if}}" data-action="open-calendar-day" data-date='{{this.payload}}'>
                    <strong>{{this.number}}</strong>
                    {{#if this.name}}<span>{{this.name}}</span>{{/if}}
                    {{#if this.noteCount}}<em>{{this.noteCount}} notes</em>{{/if}}
                  </button>
                {{/each}}
              </div>
            {{else}}
              <div class="gm-callout">
                <p>Simple Calendar Reborn is not readable yet. Once it is active, Vital Quest will show the current month here.</p>
              </div>
            {{/if}}
          </div>
          <div class="gm-form-grid four">
            <label>
              <span>Term</span>
              <input type="text" name="calendar.term" value="{{data.calendar.term}}">
            </label>
            <label>
              <span>Week</span>
              <input type="number" min="1" name="calendar.week" value="{{data.calendar.week}}">
            </label>
            <label>
              <span>Day</span>
              <input type="text" value="{{data.calendar.day}}" readonly>
            </label>
            <label>
              <span>Time</span>
              <input type="text" value="{{data.calendar.timeOfDay}}" readonly>
            </label>
          </div>
          <div class="school-agenda">
            <header class="agenda-header">
              <div>
                <span class="section-label">Read from Simple Calendar Notes</span>
                <h3>Remaining Today</h3>
              </div>
              <small>{{schoolAgenda.currentDay}} {{#if schoolAgenda.currentTime}}&middot; {{schoolAgenda.currentTime}}{{/if}}</small>
            </header>
            <div class="agenda-list">
              {{#each livingSchedule.today}}
                <article class="agenda-item">
                  <i class="fas {{this.icon}}"></i>
                  <div>
                    <strong>{{this.title}}</strong>
                    <span>{{this.type}} &middot; {{this.day}} &middot; {{this.time}}</span>
                    {{#if this.subtitle}}<small>{{this.subtitle}}</small>{{/if}}
                  </div>
                  <em>{{this.source}}</em>
                </article>
              {{else}}
                <div class="gm-callout">
                  <p>No remaining Simple Calendar notes for today. Add events by clicking a date on the month board.</p>
                </div>
              {{/each}}
            </div>
          </div>
        </article>
        <article class="gm-panel">
          <h2>Upcoming Schedule</h2>
          <p class="gm-muted">Vital Quest reads Simple Calendar Reborn as the clock, then shows the rest of today and tomorrow. As time passes, past entries fall away.</p>
          <div class="agenda-list compact">
            {{#each livingSchedule.upcoming}}
              <article class="agenda-item">
                <i class="fas {{this.icon}}"></i>
                <div>
                  <strong>{{this.title}}</strong>
                  <span>{{this.type}} &middot; {{this.day}} &middot; {{this.time}}</span>
                  {{#if this.subtitle}}<small>{{this.subtitle}}</small>{{/if}}
                </div>
              </article>
            {{else}}
              <div class="gm-callout">
                <p>No Simple Calendar notes found for today or tomorrow. Click a calendar date to plan classes, exams, clubs, campus events, or story beats.</p>
              </div>
            {{/each}}
          </div>
        </article>
      </section>
    </section>

    <section class="gm-tab-page {{#if activeTabs.story}}active{{/if}}" data-gm-page="story">
      <article class="gm-panel">
        <header class="gm-panel-header">
          <h2>Campaign Threads</h2>
          <button type="button" data-action="add-row" data-collection="quests">Add Thread</button>
        </header>
        <div class="gm-table">
          {{#each data.quests}}
            <div class="gm-row quests">
              <input data-action="save-row" data-collection="quests" data-id="{{this.id}}" data-field="title" value="{{this.title}}" placeholder="Thread">
              <input data-action="save-row" data-collection="quests" data-id="{{this.id}}" data-field="type" value="{{this.type}}" placeholder="Type">
              <input data-action="save-row" data-collection="quests" data-id="{{this.id}}" data-field="status" value="{{this.status}}" placeholder="Status">
              <textarea data-action="save-row" data-collection="quests" data-id="{{this.id}}" data-field="notes" placeholder="Notes">{{this.notes}}</textarea>
              <button type="button" class="icon danger" data-action="delete-row" data-collection="quests" data-id="{{this.id}}"><i class="fas fa-trash"></i></button>
            </div>
          {{/each}}
        </div>
      </article>
    </section>

    <section class="gm-tab-page {{#if activeTabs.tools}}active{{/if}}" data-gm-page="tools">
      <section class="tools-control-room">
        <article class="gm-panel tools-hero">
          <div>
            <span class="section-label">Control Room</span>
            <h2>Vital Quest Tools</h2>
            <p>Configure campaign-wide options, sync the Journal archive, reference standing rules, and generate quick inspiration without leaving the GM screen.</p>
          </div>
          <button type="button" data-action="save-tools-settings"><i class="fas fa-save"></i> Save Tool Settings</button>
        </article>

        <section class="tools-grid">
          <article class="gm-panel tools-card tools-settings-card">
            <header class="tools-card-header">
              <i class="fas fa-sliders-h"></i>
              <div>
                <span class="section-label">Setup</span>
                <h2>Campaign Settings</h2>
              </div>
            </header>
            <p class="gm-muted">These choices affect dropdowns and school structure across Vital Quest.</p>
            <div class="gm-form-grid">
              <label>
                <span>Number of School Years</span>
                <input type="number" min="1" max="10" step="1" name="tools.schoolYearCount" value="{{toolSettings.schoolYearCount}}">
                <small>Controls the Year dropdown on student enrollment records.</small>
              </label>
            </div>
          </article>

          <article class="gm-panel tools-card tools-wide">
            <header class="tools-card-header">
              <i class="fas fa-user-tie"></i>
              <div>
                <span class="section-label">Editable Lists</span>
                <h2>Faculty Dropdowns</h2>
              </div>
            </header>
            <p class="gm-muted">Put one option per line. Existing custom values stay available on their current records until changed.</p>
            <div class="gm-form-grid two">
              <label>
                <span>Faculty Roles</span>
                <textarea name="tools.facultyRoles" placeholder="Professor&#10;Dean&#10;Librarian">{{toolSettings.facultyRolesText}}</textarea>
              </label>
              <label>
                <span>Faculty Departments</span>
                <textarea name="tools.facultyDepartments" placeholder="Silverquill&#10;General Studies&#10;Staff">{{toolSettings.facultyDepartmentsText}}</textarea>
              </label>
            </div>
          </article>

          <article class="gm-panel tools-card">
            <header class="tools-card-header">
              <i class="fas fa-folder-tree"></i>
              <div>
                <span class="section-label">Archive</span>
                <h2>Journal Sync</h2>
              </div>
            </header>
            <p>Creates or repairs the Vital Quest Journal folder system without duplicating folders that already exist.</p>
            <div class="tools-action-box">
              <button type="button" data-action="sync-journal"><i class="fas fa-arrows-rotate"></i> Sync Journal Archive</button>
              <small>Records live under Journal &gt; Vital Quest. Actor sheets stay linked.</small>
            </div>
          </article>

          <article class="gm-panel tools-card tools-generator-card">
            <header class="tools-card-header">
              <i class="fas fa-wand-sparkles"></i>
              <div>
                <span class="section-label">Generator</span>
                <h2>Campus Event</h2>
              </div>
            </header>
            <div class="tools-result-box">
              <p>{{#if data.generated.event}}{{data.generated.event}}{{else}}No event generated yet.{{/if}}</p>
            </div>
            <button type="button" data-action="generate-event"><i class="fas fa-wand-sparkles"></i> Generate Event</button>
          </article>

          <article class="gm-panel tools-card tools-generator-card">
            <header class="tools-card-header">
              <i class="fas fa-comment-dots"></i>
              <div>
                <span class="section-label">Generator</span>
                <h2>Rumor</h2>
              </div>
            </header>
            <div class="tools-result-box">
              <p>{{#if data.generated.rumor}}{{data.generated.rumor}}{{else}}No rumor generated yet.{{/if}}</p>
            </div>
            <button type="button" data-action="generate-rumor"><i class="fas fa-comment-dots"></i> Generate Rumor</button>
          </article>

          <article class="gm-panel tools-card tools-wide standing-reference-card">
            <header class="tools-card-header">
              <i class="fas fa-scale-balanced"></i>
              <div>
                <span class="section-label">Reference</span>
                <h2>Academic Standing</h2>
              </div>
            </header>
            <p>Standing replaces GPA. It represents academic trust, discipline, faculty confidence, campus reputation, and expulsion risk.</p>
            <div class="standing-ladder compact">
              <div><strong>75 to 100</strong><span>Honored Scholar</span></div>
              <div><strong>50 to 74</strong><span>Distinguished</span></div>
              <div><strong>25 to 49</strong><span>Commended</span></div>
              <div><strong>5 to 24</strong><span>Good Standing</span></div>
              <div><strong>-4 to 4</strong><span>Watched</span></div>
              <div><strong>-20 to -5</strong><span>Concern</span></div>
              <div><strong>-40 to -21</strong><span>Probation</span></div>
              <div><strong>-60 to -41</strong><span>Final Warning</span></div>
              <div><strong>-80 to -61</strong><span>Expulsion Review</span></div>
              <div><strong>-100 to -81</strong><span>Expelled</span></div>
            </div>
          </article>

          <details class="gm-panel tools-card tools-wide standing-reference-card tools-reference-drawer">
            <summary>
              <span><i class="fas fa-list-check"></i> Example Standing Changes</span>
              <small>Open quick reference</small>
            </summary>
            <div class="standing-change-grid">
              <section>
                <span class="section-label">Academic</span>
                <div class="standing-change-list">
                  <div><span>Ace exam</span><strong>+6</strong></div>
                  <div><span>Pass exam</span><strong>+3</strong></div>
                  <div><span>Fail exam</span><strong>-4</strong></div>
                  <div><span>Miss exam</span><strong>-8</strong></div>
                  <div><span>Major class project success</span><strong>+5</strong></div>
                  <div><span>Academic competition win</span><strong>+8</strong></div>
                  <div><span>Help another student study</span><strong>+2</strong></div>
                </div>
              </section>
              <section>
                <span class="section-label">Discipline</span>
                <div class="standing-change-list">
                  <div><span>Caught cheating</span><strong>-15</strong></div>
                  <div><span>Minor rule violation</span><strong>-4</strong></div>
                  <div><span>Restricted area violation</span><strong>-8</strong></div>
                  <div><span>Property damage</span><strong>-10</strong></div>
                  <div><span>Magical endangerment</span><strong>-15 to -25</strong></div>
                  <div><span>Ignored faculty warning</span><strong>-3</strong></div>
                  <div><span>Repeated absence</span><strong>-5</strong></div>
                </div>
              </section>
              <section>
                <span class="section-label">Redemption</span>
                <div class="standing-change-list">
                  <div><span>Completed detention</span><strong>+4</strong></div>
                  <div><span>Faculty recommendation</span><strong>+8</strong></div>
                  <div><span>Community service</span><strong>+5</strong></div>
                  <div><span>Apology or reparations</span><strong>+4</strong></div>
                  <div><span>Heroic campus action</span><strong>+10 to +20</strong></div>
                </div>
              </section>
              <section>
                <span class="section-label">Social & Clubs</span>
                <div class="standing-change-list">
                  <div><span>Club leadership</span><strong>+4</strong></div>
                  <div><span>Club competition win</span><strong>+6</strong></div>
                  <div><span>Public embarrassment</span><strong>-3</strong></div>
                  <div><span>Major campus scandal</span><strong>-10</strong></div>
                  <div><span>Helped faculty or staff</span><strong>+5</strong></div>
                </div>
              </section>
            </div>
          </details>

          <article class="gm-panel tools-card danger-zone tools-danger-card">
            <header class="tools-card-header">
              <i class="fas fa-triangle-exclamation"></i>
              <div>
                <span class="section-label">Danger Zone</span>
                <h2>Reset Vital Quest</h2>
              </div>
            </header>
            <p>Wipe all Vital Quest campaign-manager data for this world.</p>
            <button type="button" class="danger" data-action="reset-manager"><i class="fas fa-rotate-left"></i> Reset Data</button>
          </article>
        </section>
      </section>
    </section>
  </main>
</form>

