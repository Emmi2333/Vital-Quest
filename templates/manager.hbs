<form class="scm-shell gm-screen college-{{collegeKey}}">
  <header class="gm-topbar">
    <div class="gm-brand-lockup">
      <div class="gm-brand-mark">
        <i class="fas fa-gem"></i>
      </div>
      <div>
        <p class="scm-kicker">Vital Quest</p>
        <h1>Strixhaven Game Master Screen</h1>
        <span class="gm-subtitle">Campaign command crystal for school life, schedules, records, and secrets</span>
      </div>
    </div>
    <div class="gm-topbar-actions">
      <span class="gm-save-hint">World records update when saved</span>
      <button type="button" data-action="save-all-changes"><i class="fas fa-save"></i> Save Changes</button>
    </div>
  </header>

  <nav class="gm-tabs" aria-label="GM screen sections">
    <button type="button" class="{{#if activeTabs.overview}}active{{/if}}" data-gm-tab="overview"><i class="fas fa-home"></i><span>Overview</span></button>
    <button type="button" class="{{#if activeTabs.students}}active{{/if}}" data-gm-tab="students"><i class="fas fa-user-graduate"></i><span>Students</span></button>
    <button type="button" class="{{#if activeTabs.faculty}}active{{/if}}" data-gm-tab="faculty"><i class="fas fa-chalkboard-teacher"></i><span>Faculty</span></button>
    <button type="button" class="{{#if activeTabs.classes}}active{{/if}}" data-gm-tab="classes"><i class="fas fa-book-open"></i><span>Classes</span></button>
    <button type="button" class="{{#if activeTabs.exams}}active{{/if}}" data-gm-tab="exams"><i class="fas fa-scroll"></i><span>Exams</span></button>
    <button type="button" class="{{#if activeTabs.clubs}}active{{/if}}" data-gm-tab="clubs"><i class="fas fa-users"></i><span>Clubs</span></button>
    <button type="button" class="{{#if activeTabs.jobs}}active{{/if}}" data-gm-tab="jobs"><i class="fas fa-briefcase"></i><span>Jobs</span></button>
    <button type="button" class="{{#if activeTabs.campus}}active{{/if}}" data-gm-tab="campus"><i class="fas fa-map-marker-alt"></i><span>Campus</span></button>
    <button type="button" class="{{#if activeTabs.calendar}}active{{/if}}" data-gm-tab="calendar"><i class="fas fa-calendar-alt"></i><span>Calendar</span></button>
    <button type="button" class="{{#if activeTabs.story}}active{{/if}}" data-gm-tab="story"><i class="fas fa-feather-alt"></i><span>Story</span></button>
    <button type="button" class="{{#if activeTabs.tools}}active{{/if}}" data-gm-tab="tools"><i class="fas fa-tools"></i><span>Tools</span></button>
  </nav>

  <main class="gm-tab-screen">
    <section class="gm-tab-page {{#if activeTabs.overview}}active{{/if}}" data-gm-page="overview">
      <section class="overview-command">
        <article class="gm-panel overview-clock-card">
          <header class="gm-panel-header">
            <div>
              <span class="section-label">School Clock</span>
              <h2>{{data.calendar.day}}</h2>
              <p>{{#if data.calendar.dateLabel}}{{data.calendar.dateLabel}}{{else}}{{data.calendar.term}} &middot; Week {{data.calendar.week}}{{/if}}</p>
            </div>
            <button type="button" data-action="advance-day"><i class="fas fa-sun"></i> Advance Day</button>
          </header>
          <div class="clock-face">
            <strong>{{data.calendar.timeOfDay}}</strong>
            <span>{{data.calendar.source}}</span>
          </div>
          <div class="gm-form-grid four overview-clock-edit">
            <label><span>Term</span><input type="text" name="calendar.term" value="{{data.calendar.term}}"></label>
            <label><span>Week</span><input type="number" min="1" name="calendar.week" value="{{data.calendar.week}}"></label>
            <label>
              <span>Fallback Day</span>
              <select name="calendar.day">
                <option {{#if (eq data.calendar.day "Moonday")}}selected{{/if}}>Moonday</option>
                <option {{#if (eq data.calendar.day "Toilsday")}}selected{{/if}}>Toilsday</option>
                <option {{#if (eq data.calendar.day "Wandsday")}}selected{{/if}}>Wandsday</option>
                <option {{#if (eq data.calendar.day "Thelsday")}}selected{{/if}}>Thelsday</option>
                <option {{#if (eq data.calendar.day "Fryday")}}selected{{/if}}>Fryday</option>
                <option {{#if (eq data.calendar.day "Standday")}}selected{{/if}}>Standday</option>
                <option {{#if (eq data.calendar.day "Sunsday")}}selected{{/if}}>Sunsday</option>
              </select>
            </label>
            <label>
              <span>Fallback Time</span>
              <select name="calendar.timeOfDay">
                <option {{#if (eq data.calendar.timeOfDay "Morning")}}selected{{/if}}>Morning</option>
                <option {{#if (eq data.calendar.timeOfDay "Afternoon")}}selected{{/if}}>Afternoon</option>
                <option {{#if (eq data.calendar.timeOfDay "Evening")}}selected{{/if}}>Evening</option>
                <option {{#if (eq data.calendar.timeOfDay "Night")}}selected{{/if}}>Night</option>
              </select>
            </label>
          </div>
        </article>

        <article class="gm-panel overview-director-card">
          <span class="section-label">Campaign Lens</span>
          <h2>{{data.focus.currentArc}}</h2>
          <div class="gm-form-grid two">
            <label>
              <span>College Theme</span>
              <select name="focus.college">
                {{#each colleges}}
                  <option value="{{this.key}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
              </select>
            </label>
            <label><span>Current Arc</span><input type="text" name="focus.currentArc" value="{{data.focus.currentArc}}"></label>
          </div>
          <label><span>Active Mystery</span><textarea name="focus.activeMystery">{{data.focus.activeMystery}}</textarea></label>
          <label><span>Public Notes for Today</span><textarea name="calendar.notes">{{data.calendar.notes}}</textarea></label>
        </article>
      </section>

      <section class="gm-stat-strip overview-stat-strip">
        <div><span>Students</span><strong>{{overviewSummary.studentsTotal}}</strong><small>{{overviewSummary.playerCount}} players &middot; {{overviewSummary.npcCount}} NPCs</small></div>
        <div><span>Classes</span><strong>{{overviewSummary.classCount}}</strong><small>Active course records</small></div>
        <div><span>Exams</span><strong>{{overviewSummary.examCount}}</strong><small>Open exams/projects</small></div>
        <div><span>Campus Life</span><strong>{{overviewSummary.clubCount}} / {{overviewSummary.jobCount}}</strong><small>clubs with members / active jobs</small></div>
      </section>

      <section class="overview-grid">
        <article class="gm-panel overview-schedule-panel">
          <header class="agenda-header">
            <div>
              <span class="section-label">Live Schedule</span>
              <h3>Today & Next Bell</h3>
            </div>
            <small>{{livingSchedule.source}}</small>
          </header>
          <div class="agenda-list">
            {{#each livingSchedule.upcoming}}
              <article class="agenda-item">
                <i class="fas {{this.icon}}"></i>
                <div><strong>{{this.title}}</strong><span>{{this.subtitle}}</span><small>{{this.source}}</small></div>
                <em>{{this.status}}</em>
              </article>
            {{else}}
              <div class="gm-callout"><p>No upcoming schedule items found. Add classes, exams, clubs, jobs, or story beats to the Calendar tab.</p></div>
            {{/each}}
          </div>
        </article>

        <article class="gm-panel overview-alert-panel">
          <span class="section-label">DM Alerts</span>
          <h2>Attention Queue</h2>
          <div class="overview-alert-list">
            {{#each overviewSummary.alerts}}
              <div><i class="fas fa-wand-sparkles"></i><span>{{this}}</span></div>
            {{/each}}
          </div>
          <div class="overview-prompt-grid">
            <section><strong>Campus Event</strong><p>{{#if data.generated.event}}{{data.generated.event}}{{else}}No event generated yet.{{/if}}</p></section>
            <section><strong>Rumor</strong><p>{{#if data.generated.rumor}}{{data.generated.rumor}}{{else}}No rumor generated yet.{{/if}}</p></section>
          </div>
        </article>
      </section>

      <section class="gm-panel overview-student-feed">
        <header class="gm-panel-header">
          <div>
            <span class="section-label">Student Card Feed</span>
            <h2>School Life Snapshot</h2>
          </div>
          <small>{{overviewSummary.employedCount}} employed &middot; {{overviewSummary.clubMemberCount}} in clubs &middot; {{overviewSummary.watchedCount}} watched</small>
        </header>
        <div class="overview-feed-sections">
          <section>
            <div class="overview-feed-heading">
              <span>Player Characters</span>
              <small>{{overviewSummary.playerCount}} tracked</small>
            </div>
            <div class="overview-student-card-grid">
              {{#each overviewSummary.playerFeed}}
                <article class="overview-student-card player">
                  <header>
                    <strong>{{this.name}}</strong>
                    <span>{{this.standing}}</span>
                  </header>
                  <p>{{this.detailLine}}</p>
                  <footer>
                    <small>Standing {{this.standingScore}}</small>
                    <button type="button" data-action="select-student" data-id="{{this.id}}">Open</button>
                  </footer>
                </article>
              {{else}}
                <div class="gm-callout"><p>No player character student records yet.</p></div>
              {{/each}}
            </div>
          </section>
          <section>
            <div class="overview-feed-heading">
              <span>Student NPCs</span>
              <small>{{overviewSummary.npcCount}} tracked</small>
            </div>
            <div class="overview-student-card-grid">
              {{#each overviewSummary.npcFeed}}
                <article class="overview-student-card npc">
                  <header>
                    <strong>{{this.name}}</strong>
                    <span>{{this.standing}}</span>
                  </header>
                  <p>{{this.detailLine}}</p>
                  <footer>
                    <small>Standing {{this.standingScore}}</small>
                    <button type="button" data-action="select-student" data-id="{{this.id}}">Open</button>
                  </footer>
                </article>
              {{else}}
                <div class="gm-callout"><p>No student NPC records yet.</p></div>
              {{/each}}
            </div>
          </section>
        </div>
      </section>
    </section>

    <section class="gm-tab-page {{#if activeTabs.students}}active{{/if}}" data-gm-page="students">
      <section class="student-manager student-command-center">
        <aside class="student-roster student-directory gm-panel">
          <header class="student-directory-header">
            <div>
              <span class="section-label">Student Records</span>
              <h2>Roster</h2>
            </div>
            <button type="button" data-action="add-student"><i class="fas fa-user-plus"></i> Add</button>
          </header>

          <div class="student-roster-stats">
            <div><strong>{{studentStats.totalCount}}</strong><span>Total</span></div>
            <div><strong>{{studentStats.playerCount}}</strong><span>PCs</span></div>
            <div><strong>{{studentStats.npcCount}}</strong><span>Students</span></div>
          </div>

          <label class="student-search-wrap">
            <span>Search records</span>
            <input class="student-search" type="search" value="{{studentSearch}}" placeholder="Name, college, standing..." data-action="student-search">
          </label>

          <div class="student-folder-heading">
            <i class="fas fa-folder-open"></i>
            <span>Player Characters</span>
          </div>
          <div class="student-roster-list">
            {{#each playerStudents}}
              <button type="button" class="student-roster-card {{#if this.selected}}active{{/if}}" data-action="select-student" data-id="{{this.id}}" data-search="{{this.name}} {{this.player}} {{this.college}} {{this.year}} {{this.academicStanding}} {{this.reputation}} {{this.actorName}}">
                {{#if this.img}}<img src="{{this.img}}" alt="{{this.name}}">{{/if}}
                <div>
                  <strong>{{this.name}}</strong>
                  <span>{{this.player}}</span>
                  <small>{{this.college}} &middot; {{this.academicStanding}}</small>
                </div>
              </button>
            {{else}}
              <p class="gm-muted">No player character records found.</p>
            {{/each}}
          </div>

          <div class="student-folder-heading">
            <i class="fas fa-folder-tree"></i>
            <span>Students by College</span>
          </div>
          {{#each studentCollegeGroups}}
            <details class="student-college-group" open>
              <summary>{{this.name}} <span>{{this.students.length}}</span></summary>
              <div class="student-roster-list">
                {{#each this.students}}
                  <button type="button" class="student-roster-card {{#if this.selected}}active{{/if}}" data-action="select-student" data-id="{{this.id}}" data-search="{{this.name}} {{this.player}} {{this.college}} {{this.year}} {{this.academicStanding}} {{this.reputation}} {{this.actorName}}">
                    {{#if this.img}}<img src="{{this.img}}" alt="{{this.name}}">{{/if}}
                    <div>
                      <strong>{{this.name}}</strong>
                      <span>{{this.college}} &middot; {{this.year}}</span>
                      <small>{{this.academicStanding}} &middot; {{this.academicStandingScore}}</small>
                    </div>
                  </button>
                {{/each}}
              </div>
            </details>
          {{else}}
            <p class="gm-muted">No student NPCs are enrolled yet.</p>
          {{/each}}
        </aside>

        {{#if selectedStudent}}
          <section class="student-profile student-dossier">
            <article class="student-dossier-hero gm-panel">
              <div class="student-portrait">
                {{#if selectedStudent.img}}<img src="{{selectedStudent.img}}" alt="{{selectedStudent.name}}">{{else}}<i class="fas fa-user-graduate"></i>{{/if}}
              </div>
              <div class="student-title-block">
                <span class="section-label">{{#if selectedStudent.hasActor}}Linked Actor Record{{else}}VQ School Record{{/if}}</span>
                <h2>{{selectedStudent.name}}</h2>
                <p>{{selectedStudent.college}} &middot; {{selectedStudent.year}} &middot; {{selectedStudent.academicStanding}}</p>
                <div class="student-tag-strip">
                  <span>{{#if selectedStudent.hasActor}}Actor linked{{else}}No actor linked{{/if}}</span>
                  <span>Standing {{selectedStudent.academicStandingScore}}</span>
                  <span>{{selectedStudent.reputation}}</span>
                </div>
              </div>
              <div class="student-profile-actions">
                <button type="button" data-action="open-actor" data-actor-id="{{selectedStudent.actorId}}"><i class="fas fa-user"></i> Actor Sheet</button>
              </div>
            </article>

            <header class="student-memory-title">
              <div>
                <span class="section-label">Strixhaven Memories</span>
                <h2>Student Record Sheet</h2>
              </div>
              <small>School-life tracking only. Actor sheet remains the source for mechanics.</small>
            </header>

            <section class="student-dossier-grid">
              <article class="gm-panel student-section-wide memory-panel memory-identity">
                <header class="student-section-header">
                  <div>
                    <span class="section-label">Enrollment</span>
                    <h2>Identity & Placement</h2>
                  </div>
                  <small>Journal route: {{selectedJournalRoute}}</small>
                </header>
                <div class="gm-form-grid three">
                  <label><span>Name</span><input data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="name" value="{{selectedStudent.name}}" {{#if selectedStudent.hasActor}}readonly{{/if}}></label>
                  <label><span>Player</span><input data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="player" value="{{selectedStudent.player}}" {{#if selectedStudent.hasActor}}readonly{{/if}}></label>
                  <label><span>College</span>
                    <select data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="college">
                      {{#each selectedCollegeOptions}}
                        <option value="{{this.label}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label><span>Year</span>
                    <select data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="year">
                      {{#each selectedYearOptions}}
                        <option value="{{this.label}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                  <label><span>Dorm Name</span><input data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="dormName" value="{{selectedStudent.dormName}}" placeholder="Dormitory, hall, or residence"></label>
                  <label><span>Dorm Number</span><input data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="dorm" value="{{selectedStudent.dorm}}" placeholder="Room or dorm number"></label>
                  <label class="faculty-picker-field"><span>Faculty Advisor</span>
                    <select data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="advisorFacultyId">
                      {{#each selectedAdvisorOptions}}
                        <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                      {{/each}}
                    </select>
                  </label>
                </div>
                <p class="gm-muted">Hit points, spells, inventory, equipment, and ability scores stay on the Foundry actor sheet.</p>
              </article>

              <article class="gm-panel memory-panel memory-report-card">
                <span class="section-label">Report Card</span>
                <h2>Academic Progress</h2>
                <div class="student-mini-stats two">
                  <label><span>Standing Score</span><input type="number" min="-100" max="100" data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="academicStandingScore" value="{{selectedStudent.academicStandingScore}}"></label>
                  <label><span>Standing Level</span><input value="{{selectedStudent.academicStanding}}" readonly></label>
                </div>
                <div class="student-class-picker">
                  <span>Current Classes</span>
                  {{#each selectedClassOptions}}
                    <label class="student-class-option">
                      <input type="checkbox" data-action="toggle-student-class" data-student-id="{{../selectedStudent.id}}" data-class-id="{{this.id}}" {{#if this.selected}}checked{{/if}}>
                      <strong>{{this.name}}</strong>
                      <small>{{#if this.professorName}}{{this.professorName}}{{else}}No professor assigned{{/if}}</small>
                    </label>
                  {{else}}
                    <p class="gm-muted">No classes have been added yet. Add classes from the Classes tab.</p>
                  {{/each}}
                </div>
                <label><span>Homework</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="homework">{{selectedStudent.homework}}</textarea></label>
              </article>

              <article class="gm-panel memory-panel memory-student-dice">
                <span class="section-label">Student Dice</span>
                <h2>Earned d4 Skills</h2>
                <div class="student-dice-list">
                  {{#each selectedStudentDice}}
                    <div>
                      <strong>{{this.skill}}</strong>
                      <span>{{this.dice}}</span>
                      <small>{{this.count}} source{{#unless (eq this.count 1)}}s{{/unless}}</small>
                    </div>
                  {{else}}
                    <p class="gm-muted">No Student Dice earned yet. Clubs and passed exams add skill d4s here.</p>
                  {{/each}}
                </div>
              </article>

              <article class="gm-panel memory-panel memory-schedule">
                <span class="section-label">Schedule</span>
                <h2>Campus Life</h2>
                <label><span>Daily Schedule</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="dailySchedule">{{selectedStudent.dailySchedule}}</textarea></label>
                <label><span>Active School Events</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="activeEvents">{{selectedStudent.activeEvents}}</textarea></label>
              </article>

              <article class="gm-panel memory-panel memory-campus-life">
                <span class="section-label">Extracurriculars & Job</span>
                <h2>Campus Commitments</h2>
                <div class="commitment-list">
                  {{#each selectedCampusCommitments}}
                    <article>
                      <i class="fas {{this.icon}}"></i>
                      <div>
                        <strong>{{this.name}}</strong>
                        <span>{{this.type}} &middot; {{this.detail}}</span>
                        <small>{{this.note}}</small>
                      </div>
                    </article>
                  {{else}}
                    <p class="gm-muted">No clubs or jobs assigned. Use the Clubs and Jobs tabs to enroll this student.</p>
                  {{/each}}
                </div>
                <label><span>Leadership</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="leadership">{{selectedStudent.leadership}}</textarea></label>
                <label><span>Reputation</span><input data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="reputation" value="{{selectedStudent.reputation}}"></label>
              </article>

              <article class="gm-panel memory-panel memory-conduct">
                <span class="section-label">Conduct</span>
                <h2>Discipline</h2>
                <label><span>Disciplinary Record</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="discipline">{{selectedStudent.discipline}}</textarea></label>
              </article>

              <article class="gm-panel student-section-wide memory-panel memory-relationships">
                <header class="student-section-header">
                  <div>
                    <span class="section-label">Relationships</span>
                    <h2>Linked Sheets & Social Standing</h2>
                  </div>
                  <button type="button" data-action="add-relationship" data-student-id="{{selectedStudent.id}}"><i class="fas fa-link"></i> Add Link</button>
                </header>
                <p class="gm-muted">Link this student to player or NPC Actor sheets. Scores can be used for friend, beloved, rival, or enemy style tracking.</p>
                <div class="relationship-link-list">
                  {{#each selectedRelationshipLinks}}
                    <div class="relationship-link-row" data-relationship-row="{{this.id}}">
                      <div class="relationship-link-target">
                        {{#if this.targetImg}}<img src="{{this.targetImg}}" alt="{{this.targetName}}">{{else}}<i class="fas fa-user"></i>{{/if}}
                        <strong>{{this.targetName}}</strong>
                      </div>
                      <label>
                        <span>Linked Sheet</span>
                        <select data-action="save-relationship" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-field="targetActorId">
                          <option value="">Choose actor...</option>
                          {{#each this.actorOptions}}
                            <option value="{{this.id}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                          {{/each}}
                        </select>
                      </label>
                      <label>
                        <span>Score</span>
                        <input type="number" data-action="save-relationship" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-field="score" value="{{this.score}}" data-relationship-score="{{this.id}}">
                      </label>
                      <label class="relationship-point-adjuster">
                        <span>Adjust Points</span>
                        <div>
                          <button type="button" data-action="adjust-relationship-score" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-direction="-1">−</button>
                          <input type="number" min="0" step="1" value="1" data-relationship-adjust="{{this.id}}">
                          <button type="button" data-action="adjust-relationship-score" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-direction="1">+</button>
                        </div>
                      </label>
                      <label>
                        <span>Status</span>
                        <input data-action="save-relationship" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-field="status" value="{{this.status}}" data-relationship-status="{{this.id}}">
                      </label>
                      <label class="relationship-notes">
                        <span>Notes</span>
                        <textarea data-action="save-relationship" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}" data-field="notes">{{this.notes}}</textarea>
                      </label>
                      <div class="relationship-actions">
                        <button type="button" data-action="open-actor" data-actor-id="{{this.targetActorId}}" {{#unless this.hasTarget}}disabled{{/unless}}><i class="fas fa-user"></i></button>
                        <button type="button" class="danger" data-action="delete-relationship" data-student-id="{{../selectedStudent.id}}" data-relationship-id="{{this.id}}"><i class="fas fa-trash"></i></button>
                      </div>
                    </div>
                  {{else}}
                    <div class="gm-callout">
                      <p>No linked relationships yet. Add a link to connect this student to another character or NPC sheet.</p>
                    </div>
                  {{/each}}
                </div>
                <label><span>General Relationship Notes</span><textarea data-action="save-student" data-id="{{selectedStudent.id}}" data-actor-id="{{selectedStudent.actorId}}" data-field="relationships">{{selectedStudent.relationships}}</textarea></label>
              </article>

              <article class="gm-panel student-section-wide memory-panel memory-notes">
                <span class="section-label">DM Progression</span>
                <h2>Semester Notes & Graduation Track</h2>
                <div class="gm-form-grid three">
